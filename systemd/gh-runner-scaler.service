[Unit]
Description=GitHub Actions Runner Auto-Scaler
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/gh-runner-scaler daemon --config /etc/gh-runner-scaler/config.toml
EnvironmentFile=/etc/gh-runner-scaler/env
Restart=on-failure
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
